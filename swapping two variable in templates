#include <iostream>
using namespace std;

// Template function
template <typename T>
void swapVal(T &a, T &b) {
    T temp;
    temp = a;
    a = b;
    b = temp;
}

int main() {
    int x = 10, y = 20;

    cout << "Before swapping (int): " << endl;
    cout << "x = " << x << ", y = " << y << endl;

    swapVal(x, y);

    cout << "After swapping (int): " << endl;
    cout << "x = " << x << ", y = " << y << endl;

    float a = 1.5, b = 2.5;

    cout << "\nBefore swapping (float): " << endl;
    cout << "a = " << a << ", b = " << b << endl;

    swapVal(a, b);

    cout << "After swapping (float): " << endl;
    cout << "a = " << a << ", b = " << b << endl;

    return 0;
}
